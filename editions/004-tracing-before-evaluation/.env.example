# Use your W&B API key for both Weave tracing and W&B Inference.
WANDB_API_KEY=your_wandb_api_key

# Use entity/project for W&B Inference usage tracking and Weave traces.
WANDB_PROJECT=your-team/ai-engineering-in-production

# Optional: change these if you want to try another W&B Inference model or URL.
WANDB_MODEL=meta-llama/Llama-3.1-8B-Instruct
WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1
